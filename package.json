{
  "name": "tipig",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "predev": "npm run build:albums",
    "build": "npm run typecheck && vite build",
    "prebuild": "npm run build:albums",
    "preview": "npm run build && wrangler dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "preverify": "npm run build:albums",
    "verify": "npm run typecheck && npm test && npm run test:e2e",
    "measure": "tsx scripts/measure.ts",
    "build:albums": "tsx scripts/build-albums.ts",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.38.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  }
}
